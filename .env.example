# --- Cloud LLM API keys (when not using Databricks for those providers)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- Databricks model serving (llm_provider "databricks")
# Workspace URL, no trailing slash. Required when DEEP_/QUICK_THINK_LLM are
# endpoint names only (e.g. databricks-claude-opus-4-6).
DATABRICKS_HOST=https://dbc-xxxxx.cloud.databricks.com
DATABRICKS_TOKEN=
# Endpoint names OR full .../serving-endpoints/<name>/invocations URLs
DEEP_THINK_LLM=databricks-claude-opus-4-6
QUICK_THINK_LLM=databricks-gpt-5-4-nano

# --- Optional: not referenced by the stock data stack today (defaults use yfinance)
FINNHUB_API_KEY=
